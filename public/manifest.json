{
    "manifest_version": 3,
    "name": "LLM Orchestrator",
    "version": "1.5.6",
    "description": "Extracts Gemini and ChatGPT chat history and saves it as a Markdown file.",
    "permissions": [
        "activeTab",
        "scripting",
        "clipboardWrite",
        "storage",
        "tabs"
    ],
    "host_permissions": [
        "https://gemini.google.com/*",
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://*.openai.com/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_popup": "popup.html"
    }
}