{
    "manifest_version": 3,
    "name": "LLM Orchestrator",
    "version": "1.5.18",
    "description": "Extracts Gemini and ChatGPT chat history and saves it as a Markdown file.",
    "permissions": [
        "activeTab",
        "scripting",
        "clipboardWrite",
        "storage",
        "tabs",
        "sidePanel"
    ],
    "host_permissions": [
        "https://gemini.google.com/*",
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://*.openai.com/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_title": "Open Side Panel"
    },
    "side_panel": {
        "default_path": "panel.html"
    }
}